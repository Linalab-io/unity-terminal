{
  "schema_version": 1,
  "retention_days": 90,
  "archive_days": 90,
  "hot_threshold": 3,
  "hot_recent_days": 7,
  "max_keywords": 10,
  "default_search_limit": 10,
  "queue_batch_limit": 100,
  "snippet_chars": 220,
  "keyword_overlap_threshold": 0.8,
  "jaccard_threshold": 0.8,
  "min_token_length": 3,
  "supported_types": ["learnings", "decisions", "issues", "problems"],
  "canonical_notepads_dir": ".sisyphus/notepads",
  "queue_dir": ".sisyphus/rag/queue",
  "archive_dir": ".sisyphus/rag/archive"
}
